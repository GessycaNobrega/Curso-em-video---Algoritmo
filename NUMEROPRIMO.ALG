algoritmo "NumeroPrimo"
var
   C, N, ContDiv: Inteiro
inicio
   C <- 1
   ContDiv <- 0
   Escreva ("Digite um n·mero: ")
   Leia (N)
   Repita
      Escreva (C)
      Se (N % C = 0) entao
         ContDiv <- ContDiv + 1
      FimSe
      C <- C + 1
    AtÚ (C > N)
        Escreval  (" Ao todo existes ", ContDiv, " valores divisiveis")
    Se (ContDiv > 2) entao
    Escreval (" O valor ", N, "nÒo Ú primo")
    Senao
    Escreval (" O valor ", N, " Ú primo")
    FimSe
    

fimalgoritmo