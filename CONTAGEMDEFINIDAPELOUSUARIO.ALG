algoritmo "contagemDefinidapeloUsuario"
var
   valor, contador: Inteiro
inicio
      contador <- 0
      Escreval ("Quer contar até quanto?")
      Leia (valor)
      Enquanto (contador <=valor) faca
      Escreval (Contador)
               contador <- contador + 1
      FimEnquanto
      Escreval ("Terminei de contar")
fimalgoritmo