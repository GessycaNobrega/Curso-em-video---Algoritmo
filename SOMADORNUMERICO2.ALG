algoritmo "somadorNumerico3"
var
   Cont, N, S, maior: Inteiro
inicio
      Cont <- 1
      S <- 0
      Enquanto (Cont <=10) faca
      Escreva ("Digite o", cont, "o. valor: ")
      Leia (N)
      Se (N > maior) entao
      maior <- N
      FimSe
      S <- S + N
      Cont <- Cont + 1
      FimEnquanto
      Escreva("A soma de todos os valores È de: ", S)
fimalgoritmo