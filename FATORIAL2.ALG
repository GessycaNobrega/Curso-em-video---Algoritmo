algoritmo "Fatorial2"
var
   C, N, F: Inteiro
   R: Caractere
inicio
   Repita
      Escreval ("Escreva um n·mero: ")
      Leia (N)
      C <- N
      F <- 1
      Repita
         F <- F * C
         C <- C - 1
      Ate (C < 1)
      Escreva ("O valor do fatorial de ", N, " ķ igual a ", F)
      Escreval ("Quer continuar? [S/N]")
      Leia (R)
      LimpaTela
   Atķ (R = "N")

fimalgoritmo